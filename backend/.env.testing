APP_NAME=SmartFish
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smartfish_test
DB_USERNAME=root
DB_PASSWORD=secret

QUEUE_CONNECTION=sync
SESSION_DRIVER=array
CACHE_STORE=array

FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# No SSL needed — this connects to the MySQL service container inside
# the GitHub Actions runner, not PlanetScale.
